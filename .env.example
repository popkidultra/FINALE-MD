# ==== Session ====
# Paste the value from your POPKID-MD session ID generator/pairing site here.
# Format: "POPKID~<base64 payload>" — a self-contained string, no external
# download needed. Legacy prefixes F~, SILA-MD~, and NEXUS___ are also accepted.
# Leave blank to authenticate via QR code on first run instead.
SESSION_ID=

# ==== Identity ====
